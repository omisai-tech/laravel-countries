{
    "name": "omisai/<package_name>",
    "description": "<package_description>",
    "keywords": [],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Omisai\\<package_name>\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/omisai-tech/<package_name>",
    "authors": [
        {
            "name": "<author_name>",
            "email": "<author_email>",
            "homepage": "https://omisai.com"
        }
    ],
    "require-dev": {
        "pestphp/pest": "^4.3",
        "laravel/pint": "^1.27"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require": {
        "php": "^8.1"
    },
    "scripts": {
        "test": "./vendor/bin/pest --colors=always",
        "pint": "./vendor/laravel/pint/builds/pint"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}